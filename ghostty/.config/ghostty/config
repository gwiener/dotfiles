theme = light:GitHub Light Default,dark:GitHub Dark Default
cursor-style = block
cursor-style-blink = false
# shell-integration-features = no-cursor
adjust-cursor-thickness = 2
# font-family = "Monaspace Neon Medium"
font-family = "JetBrains Mono"
font-size = 14
# set inherit to false to start each time at the home dir
window-inherit-working-directory = true
macos-option-as-alt = true
unfocused-split-opacity = 0.85
keybind = global:cmd+\=toggle_quick_terminal
quick-terminal-position=center
quick-terminal-animation-duration=0
quick-terminal-size=60%,60%
keybind = shift+enter=text:\x1b\r
grapheme-width-method = unicode
keybind = cmd+ctrl+arrow_up=new_split:up
keybind = cmd+ctrl+arrow_down=new_split:down
keybind = cmd+ctrl+arrow_left=new_split:left
keybind = cmd+ctrl+arrow_right=new_split:right
keybind = cmd+u=scroll_page_lines:-25
keybind = cmd+d=scroll_page_lines:25
split-divider-color=gray
unfocused-split-fill=gray
